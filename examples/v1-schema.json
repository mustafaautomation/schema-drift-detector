{
  "openapi": "3.0.0",
  "paths": {
    "/api/users": {
      "get": { "summary": "List users", "responses": { "200": { "description": "User list" } } }
    }
  },
  "components": {
    "schemas": {
      "User": {
        "type": "object",
        "required": ["id", "email"],
        "properties": {
          "id": { "type": "integer" },
          "email": { "type": "string" },
          "name": { "type": "string" }
        }
      }
    }
  }
}
